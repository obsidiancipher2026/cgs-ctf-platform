{
  "name": "cyber-guardians-ctf",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:cleanup-pending": "tsx prisma/cleanup-pending.ts",
    "db:studio": "prisma studio",
    "db:init": "npx prisma migrate dev --name init",
    "db:switch:sqlite": "powershell -NoProfile -File scripts/switch-db.ps1 -Target sqlite",
    "db:switch:postgres": "powershell -NoProfile -File scripts/switch-db.ps1 -Target postgres",
    "vercel-build": "npx prisma db push --accept-data-loss && npx prisma generate && next build",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@react-three/drei": "^9.92.7",
    "@react-three/fiber": "^8.15.11",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.0.0",
    "framer-motion": "^10.16.16",
    "gsap": "^3.12.4",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.298.0",
    "next": "^14.0.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.6.0",
    "tailwind-merge": "^2.1.0",
    "three": "^0.160.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.10.4",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/three": "^0.160.0",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.0.4",
    "postcss": "^8.4.32",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.3.6",
    "tsx": "^4.19.0",
    "typescript": "^5.3.3"
  }
}
