// PostgreSQL schema for production (Vercel).
// For local SQLite development, switch to the SQLite schema:
//   Copy-Item prisma/schema.sqlite.prisma prisma/schema.prisma
// Or use: npm run db:switch:sqlite

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Team {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  avatarUrl   String?
  isBanned    Boolean  @default(false)
  isSuspended Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members User[]
}

model User {
  id             Int      @id @default(autoincrement())
  username       String   @unique
  email          String   @unique
  hashedPassword String
  avatarUrl      String?
  role           String   @default("player")
  status         String   @default("pending")
  isBanned       Boolean  @default(false)
  score          Int      @default(0)
  ranking        Int      @default(0)
  lastIp         String?
  lastLogin      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  teamId  Int?
  team    Team?  @relation(fields: [teamId], references: [id])

  firstName  String  @default("")
  middleName String?
  lastName   String?
  gender     String?
  country    String?
  college    String?
  ageGroup   String?
  playerType String?

  submissions Submission[]
}

model Announcement {
  id          Int       @id @default(autoincrement())
  title       String
  message     String
  isBroadcast Boolean   @default(false)
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?
}

model Log {
  id        Int       @id @default(autoincrement())
  action    String
  details   String?
  ipAddress String?
  userId    Int?
  severity  String    @default("info")
  createdAt DateTime  @default(now())
}

model AttackLog {
  id              Int       @id @default(autoincrement())
  attackType      String
  severity        String    @default("medium")
  ipAddress       String
  userId          Int?
  username        String?
  fingerprint     String?
  riskScore       Float     @default(0.0)
  endpoint        String?
  method          String?
  userAgent       String?
  payloadSnapshot String?
  headersSnapshot String?
  country         String?
  actionTaken     String    @default("logged")
  quarantineUntil Float?
  blocked         Int       @default(0)
  whitelisted     Int       @default(0)
  reviewed        Int       @default(0)
  reviewedBy      Int?
  notes           String?
  chainHash       String
  prevChainHash   String?
  createdAt       DateTime  @default(now())
}

model Challenge {
  id          Int          @id @default(autoincrement())
  title       String
  description String
  category    String
  points      Int          @default(100)
  flag        String
  hint        String?
  files       String?
  difficulty  String?
  published   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  solves      Submission[]
}

model Submission {
  id          Int       @id @default(autoincrement())
  userId      Int
  challengeId Int
  solved      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])
  challenge   Challenge @relation(fields: [challengeId], references: [id])
  @@unique([userId, challengeId])
}

model RealFlag {
  id            Int       @id @default(autoincrement())
  challengeName String
  flag          String
  category      String?
  notes         String?
  createdBy     Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model SecurityConfig {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}
